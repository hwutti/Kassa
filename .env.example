# SQLite-Datenbank (lokale Datei). Für Produktion ggf. auf Postgres wechseln.
DATABASE_URL="file:./dev.db"

# Geheimer Schlüssel zum Signieren der Admin-Session (JWT). In Produktion zwingend
# durch einen langen Zufallswert ersetzen, z. B.:  openssl rand -base64 48
AUTH_SECRET="bitte-einen-langen-zufallswert-eintragen"

# Erst-Administrator, der beim Seed angelegt wird. NICHT ins Repo committen.
ADMIN_BENUTZER="admin"
ADMIN_PASSWORT="bitte-sicheres-passwort-setzen"
